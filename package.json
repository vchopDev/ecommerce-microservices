{
    "name": "ecommerce-microservices",
    "private": true,
    "workspaces": [
        "services/*",
        "packages/*"
    ],
    "scripts": {
        "start:all": "concurrently --names \"USER,CATALOG\" --prefix-colors \"blue,green\" \"npm run start:dev --workspace=@app/user-service\" \"npm run start:dev --workspace=@app/catalog-service\"",
        "build:all": "npm run build --workspaces",
        "lint:all": "npm run lint --workspaces"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}