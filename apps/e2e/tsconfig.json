{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "types": [
            "cypress"
        ],
        "typeRoots": [
            "../../node_modules"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "cypress/**/*.ts",
        "cypress.config.ts"
    ]
}